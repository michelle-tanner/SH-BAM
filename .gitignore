# ─── Secrets ──────────────────────────────────────────────────────────────────
# Never commit credentials or environment config.
.env
.env.*
!.env.example

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# ─── SQLite database files ────────────────────────────────────────────────────
# The .db file is generated at runtime — not source code.
# The -wal and -shm files are SQLite's write-ahead log and shared memory index.
*.db
*.db-shm
*.db-wal

# ─── Backend / documents folder ───────────────────────────────────────────────
# The actual report files uploaded for indexing are not source code.
backend/docs/

# ─── LlamaIndex / ChromaDB generated index files ─────────────────────────────
# These are rebuilt by running ingest.py and should not be committed.
backend/index_store/

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
